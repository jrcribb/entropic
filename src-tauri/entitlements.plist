<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow app to use Apple's Virtualization.framework (VZ) for Colima VMs -->
    <key>com.apple.security.virtualization</key>
    <true/>
    <!-- Allow localhost TCP listener for OAuth callback (port 27100) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- Allow outgoing network connections (API calls, Docker, etc.) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Allow microphone capture for explicit in-app voice recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
