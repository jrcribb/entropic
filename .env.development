# Dev-only overrides for isolated deep-link auth
# Dev API base for Vite/browser/API calls.
# Using a relative path keeps tauri:dev browser-origin traffic same-origin,
# and routes through Vite's /api proxy to nova.qu.ai.
VITE_API_URL=/api
VITE_AUTH_REDIRECT_URL="nova-dev://auth/callback"
VITE_AUTH_STORE_NAME="nova-auth-dev.json"
VITE_INTEGRATIONS_REDIRECT_URL="nova-dev://integrations/success"
VITE_AUTH_DEBUG=1
VITE_AUTH_USE_LOCALHOST=1
